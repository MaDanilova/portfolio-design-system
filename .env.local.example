# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Security rollout controls
# monitor (default) logs suspicious origin mismatches but allows requests
# enforce blocks origin mismatches with 403 on mutating settings routes
SECURITY_ORIGIN_CHECK_MODE=monitor

# /api/review rate limiting (in-memory, per runtime instance)
REVIEW_RATE_LIMIT_IP=20
REVIEW_RATE_LIMIT_IP_WINDOW_MS=60000
REVIEW_RATE_LIMIT_USER=10
REVIEW_RATE_LIMIT_USER_WINDOW_MS=60000
